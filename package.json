{
  "name": "mimo-for-copilot",
  "displayName": "MiMo for Copilot Chat",
  "description": "Pick MiMo-v2.5-pro from the Copilot Chat model picker. Tool calling, streaming — zero config, BYOK.",
  "version": "0.3.0",
  "publisher": "mimo-copilot",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Luka07720/mimo-for-copilot"
  },
  "engines": {
    "vscode": "^1.116.0",
    "node": ">=24"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages"
  ],
  "keywords": [
    "mimo",
    "mimo-v2.5-pro",
    "xiaomi",
    "copilot",
    "github copilot",
    "copilot chat",
    "language model",
    "ai",
    "chat"
  ],
  "activationEvents": [
    "onUri",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "mimo",
        "displayName": "MiMo"
      }
    ],
    "commands": [
      {
        "command": "mimo-copilot.setApiKey",
        "title": "%mimo-copilot.command.setApiKey%"
      },
      {
        "command": "mimo-copilot.getApiKey",
        "title": "%mimo-copilot.command.getApiKey%"
      },
      {
        "command": "mimo-copilot.clearApiKey",
        "title": "%mimo-copilot.command.clearApiKey%"
      },
      {
        "command": "mimo-copilot.openSettings",
        "title": "%mimo-copilot.command.openSettings%"
      },
      {
        "command": "mimo-copilot.showLogs",
        "title": "%mimo-copilot.command.showLogs%"
      }
    ],
    "walkthroughs": [
      {
        "id": "mimoGettingStarted",
        "title": "%mimo-copilot.walkthrough.title%",
        "description": "%mimo-copilot.walkthrough.description%",
        "steps": [
          {
            "id": "setApiKey",
            "title": "%mimo-copilot.walkthrough.setApiKey.title%",
            "description": "%mimo-copilot.walkthrough.setApiKey.description%",
            "completionEvents": [
              "onCommand:mimo-copilot.setApiKey"
            ]
          },
          {
            "id": "showModels",
            "title": "%mimo-copilot.walkthrough.showModels.title%",
            "description": "%mimo-copilot.walkthrough.showModels.description%"
          }
        ]
      }
    ],
    "configuration": {
      "title": "%mimo-copilot.config.title%",
      "properties": {
        "mimo-copilot.baseUrl": {
          "type": "string",
          "default": "https://token-plan-cn.xiaomimimo.com/v1",
          "description": "%mimo-copilot.config.baseUrl.description%"
        },
        "mimo-copilot.maxTokens": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "%mimo-copilot.config.maxTokens.description%"
        },
        "mimo-copilot.modelIdOverrides": {
          "type": "object",
          "default": {
            "mimo-v2.5-pro": "mimo-v2.5-pro",
            "mimo-v2.5": "mimo-v2.5"
          },
          "description": "%mimo-copilot.config.modelIdOverrides.description%",
          "additionalProperties": false,
          "properties": {
            "mimo-v2.5-pro": {
              "type": "string",
              "description": "%mimo-copilot.config.modelIdOverrides.mimo-v2.5-pro.description%"
            },
            "mimo-v2.5": {
              "type": "string",
              "description": "%mimo-copilot.config.modelIdOverrides.mimo-v2.5.description%"
            }
          }
        },
        "mimo-copilot.inlineCompletion.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%mimo-copilot.config.inlineCompletion.enabled.description%"
        },
        "mimo-copilot.inlineCompletion.model": {
          "type": "string",
          "default": "mimo-v2.5",
          "enum": ["mimo-v2.5", "mimo-v2.5-pro"],
          "description": "%mimo-copilot.config.inlineCompletion.model.description%"
        },
        "mimo-copilot.inlineCompletion.maxTokens": {
          "type": "number",
          "default": 1024,
          "minimum": 16,
          "maximum": 4096,
          "description": "%mimo-copilot.config.inlineCompletion.maxTokens.description%"
        }
      }
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('out', { recursive: true, force: true, maxRetries: process.platform === 'win32' ? 10 : 0 })\"",
    "compile": "npm run clean && tsc -p ./",
    "watch": "npm run clean && tsc -watch -p ./",
    "package": "vsce package -o dist/"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.116.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^6.0.3"
  }
}
